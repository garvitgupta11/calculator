<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>NEXUS CALC — God-Level Cyberpunk Calculator</title>
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Orbitron:wght@400;700;900&family=Rajdhani:wght@300;400;600;700&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/mathjs/11.11.0/math.min.js"></script>
<style>
  :root {
    --cyan: #00f3ff;
    --magenta: #ff00ff;
    --cyan-dim: #00a8b5;
    --magenta-dim: #b000b0;
    --bg-deep: #020408;
    --bg-panel: #050d14;
    --bg-glass: rgba(0, 243, 255, 0.03);
    --bg-glass2: rgba(255, 0, 255, 0.03);
    --border-cyan: rgba(0, 243, 255, 0.25);
    --border-magenta: rgba(255, 0, 255, 0.2);
    --text-primary: #e0f7ff;
    --text-secondary: #7ab5c0;
    --text-dim: #3a6070;
    --neon-green: #00ff88;
    --neon-amber: #ffaa00;
    --neon-red: #ff3366;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--bg-deep);
    font-family: 'Rajdhani', sans-serif;
    color: var(--text-primary);
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* Scanlines overlay */
  body::before {
    content: '';
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0, 243, 255, 0.012) 2px,
      rgba(0, 243, 255, 0.012) 4px
    );
    pointer-events: none;
    z-index: 9999;
  }

  /* Grid bg */
  body::after {
    content: '';
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    background-image:
      linear-gradient(rgba(0,243,255,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,243,255,0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    pointer-events: none;
    z-index: 0;
  }

  .app {
    position: relative;
    z-index: 1;
    max-width: 1400px;
    margin: 0 auto;
    padding: 20px;
  }

  /* Header */
  .header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 24px;
    border: 1px solid var(--border-cyan);
    background: var(--bg-glass);
    backdrop-filter: blur(10px);
    margin-bottom: 16px;
    position: relative;
    clip-path: polygon(0 0, calc(100% - 20px) 0, 100% 20px, 100% 100%, 20px 100%, 0 calc(100% - 20px));
  }
  .header::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--cyan), var(--magenta), transparent);
    animation: scanH 4s linear infinite;
  }
  @keyframes scanH { 0%{opacity:0.4} 50%{opacity:1} 100%{opacity:0.4} }

  .logo {
    font-family: 'Orbitron', monospace;
    font-size: 22px;
    font-weight: 900;
    letter-spacing: 4px;
    background: linear-gradient(135deg, var(--cyan), var(--magenta));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    text-shadow: none;
    filter: drop-shadow(0 0 10px rgba(0,243,255,0.5));
  }

  .header-status {
    display: flex;
    gap: 16px;
    align-items: center;
    font-family: 'Share Tech Mono', monospace;
    font-size: 11px;
    color: var(--text-secondary);
  }

  .status-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--neon-green);
    box-shadow: 0 0 8px var(--neon-green);
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.6;transform:scale(0.8)} }

  /* Tabs */
  .tabs {
    display: flex;
    gap: 4px;
    margin-bottom: 16px;
    padding: 4px;
    background: rgba(0,0,0,0.4);
    border: 1px solid var(--border-cyan);
    border-radius: 4px;
    overflow-x: auto;
  }

  .tab {
    flex: 0 0 auto;
    padding: 8px 16px;
    background: transparent;
    border: 1px solid transparent;
    color: var(--text-dim);
    font-family: 'Orbitron', monospace;
    font-size: 10px;
    letter-spacing: 1px;
    cursor: pointer;
    transition: all 0.2s;
    clip-path: polygon(8px 0, 100% 0, calc(100% - 8px) 100%, 0 100%);
    white-space: nowrap;
  }
  .tab:hover { color: var(--cyan); border-color: var(--border-cyan); }
  .tab.active {
    background: rgba(0, 243, 255, 0.1);
    border-color: var(--cyan);
    color: var(--cyan);
    text-shadow: 0 0 10px var(--cyan);
  }

  /* Main layout */
  .main-grid {
    display: grid;
    grid-template-columns: 380px 1fr;
    gap: 16px;
  }

  /* Panel */
  .panel {
    background: var(--bg-glass);
    border: 1px solid var(--border-cyan);
    backdrop-filter: blur(10px);
    position: relative;
    overflow: hidden;
  }
  .panel::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 3px; height: 100%;
    background: linear-gradient(180deg, var(--cyan), transparent 60%);
  }

  .panel-header {
    padding: 10px 16px;
    border-bottom: 1px solid var(--border-cyan);
    font-family: 'Orbitron', monospace;
    font-size: 10px;
    letter-spacing: 2px;
    color: var(--cyan);
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .panel-header .ph-dot {
    width: 5px; height: 5px;
    border-radius: 50%;
    background: var(--cyan);
    box-shadow: 0 0 6px var(--cyan);
  }

  /* Display */
  .display-area {
    padding: 16px;
    background: rgba(0, 0, 0, 0.5);
    border-bottom: 1px solid var(--border-cyan);
    min-height: 100px;
  }

  .display-expr {
    font-family: 'Share Tech Mono', monospace;
    font-size: 12px;
    color: var(--text-dim);
    min-height: 18px;
    word-break: break-all;
    margin-bottom: 6px;
  }

  .display-main {
    font-family: 'Orbitron', monospace;
    font-size: 32px;
    font-weight: 700;
    color: var(--cyan);
    text-align: right;
    text-shadow: 0 0 20px var(--cyan), 0 0 40px rgba(0,243,255,0.3);
    word-break: break-all;
    min-height: 44px;
    animation: flicker 8s linear infinite;
  }
  @keyframes flicker {
    0%,95%,97%,100% { opacity: 1; }
    96% { opacity: 0.92; }
  }

  .display-mode {
    font-family: 'Share Tech Mono', monospace;
    font-size: 10px;
    color: var(--magenta);
    display: flex;
    gap: 12px;
    margin-top: 6px;
  }

  /* Button grid */
  .btn-grid {
    padding: 12px;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 6px;
  }

  .btn {
    padding: 10px 6px;
    background: rgba(0,0,0,0.6);
    border: 1px solid rgba(0,243,255,0.15);
    color: var(--text-secondary);
    font-family: 'Rajdhani', sans-serif;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.1s;
    position: relative;
    overflow: hidden;
    clip-path: polygon(4px 0, 100% 0, calc(100% - 4px) 100%, 0 100%);
    letter-spacing: 0.5px;
  }
  .btn::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, transparent 50%, rgba(0,243,255,0.05) 50%);
    opacity: 0;
    transition: opacity 0.1s;
  }
  .btn:hover {
    border-color: var(--cyan);
    color: var(--cyan);
    background: rgba(0,243,255,0.08);
    box-shadow: 0 0 10px rgba(0,243,255,0.2);
  }
  .btn:hover::after { opacity: 1; }
  .btn:active { transform: scale(0.96); }

  .btn.cyan { color: var(--cyan); border-color: rgba(0,243,255,0.4); }
  .btn.magenta { color: var(--magenta); border-color: rgba(255,0,255,0.3); }
  .btn.amber { color: var(--neon-amber); border-color: rgba(255,170,0,0.3); }
  .btn.green { color: var(--neon-green); border-color: rgba(0,255,136,0.3); }
  .btn.red { color: var(--neon-red); border-color: rgba(255,51,102,0.3); }
  .btn.wide { grid-column: span 2; }
  .btn.equal {
    background: linear-gradient(135deg, rgba(0,243,255,0.2), rgba(255,0,255,0.2));
    border-color: var(--magenta);
    color: #fff;
    text-shadow: 0 0 8px var(--magenta);
    box-shadow: inset 0 0 15px rgba(255,0,255,0.1);
  }
  .btn.equal:hover {
    background: linear-gradient(135deg, rgba(0,243,255,0.35), rgba(255,0,255,0.35));
    box-shadow: 0 0 20px rgba(255,0,255,0.4), inset 0 0 20px rgba(0,243,255,0.1);
  }

  /* Right panel tabs */
  .right-panel { display: flex; flex-direction: column; gap: 16px; }

  .content-area {
    display: none;
    flex-direction: column;
    gap: 16px;
  }
  .content-area.active { display: flex; }

  /* Feature grid */
  .feature-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 12px;
  }

  .feature-card {
    background: var(--bg-glass);
    border: 1px solid var(--border-cyan);
    padding: 14px;
    position: relative;
    transition: all 0.2s;
  }
  .feature-card::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--magenta), transparent);
    opacity: 0;
    transition: opacity 0.2s;
  }
  .feature-card:hover {
    border-color: rgba(0,243,255,0.5);
    box-shadow: 0 0 20px rgba(0,243,255,0.1);
  }
  .feature-card:hover::after { opacity: 1; }

  .fc-label {
    font-family: 'Share Tech Mono', monospace;
    font-size: 10px;
    color: var(--magenta);
    margin-bottom: 6px;
    letter-spacing: 1px;
  }
  .fc-title {
    font-family: 'Orbitron', monospace;
    font-size: 11px;
    color: var(--cyan);
    margin-bottom: 8px;
  }
  .fc-inputs { display: flex; flex-direction: column; gap: 6px; }
  .fc-input {
    background: rgba(0,0,0,0.6);
    border: 1px solid var(--border-cyan);
    color: var(--text-primary);
    padding: 6px 10px;
    font-family: 'Share Tech Mono', monospace;
    font-size: 12px;
    width: 100%;
    outline: none;
    transition: border-color 0.2s;
  }
  .fc-input:focus { border-color: var(--cyan); box-shadow: 0 0 8px rgba(0,243,255,0.2); }
  .fc-btn {
    background: rgba(0,243,255,0.1);
    border: 1px solid var(--border-cyan);
    color: var(--cyan);
    padding: 6px 12px;
    font-family: 'Orbitron', monospace;
    font-size: 10px;
    cursor: pointer;
    letter-spacing: 1px;
    transition: all 0.2s;
    width: 100%;
    margin-top: 4px;
  }
  .fc-btn:hover {
    background: rgba(0,243,255,0.2);
    box-shadow: 0 0 10px rgba(0,243,255,0.3);
  }
  .fc-result {
    font-family: 'Share Tech Mono', monospace;
    font-size: 12px;
    color: var(--neon-green);
    margin-top: 6px;
    min-height: 16px;
    word-break: break-all;
  }
  .fc-select {
    background: rgba(0,0,0,0.6);
    border: 1px solid var(--border-cyan);
    color: var(--text-primary);
    padding: 6px 10px;
    font-family: 'Share Tech Mono', monospace;
    font-size: 11px;
    width: 100%;
    outline: none;
  }

  /* History panel */
  .history-list {
    max-height: 300px;
    overflow-y: auto;
    padding: 8px 12px;
  }
  .history-list::-webkit-scrollbar { width: 4px; }
  .history-list::-webkit-scrollbar-track { background: transparent; }
  .history-list::-webkit-scrollbar-thumb { background: var(--border-cyan); border-radius: 2px; }

  .history-item {
    padding: 8px 0;
    border-bottom: 1px solid rgba(0,243,255,0.08);
    cursor: pointer;
    transition: all 0.15s;
  }
  .history-item:hover { padding-left: 6px; }
  .hi-expr { font-family: 'Share Tech Mono', monospace; font-size: 11px; color: var(--text-dim); }
  .hi-result { font-family: 'Orbitron', monospace; font-size: 14px; color: var(--cyan); }

  /* Stats bar */
  .stats-bar {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 8px;
    padding: 10px 12px;
  }
  .stat-item { text-align: center; }
  .stat-val {
    font-family: 'Orbitron', monospace;
    font-size: 16px;
    color: var(--cyan);
    display: block;
  }
  .stat-lbl {
    font-family: 'Share Tech Mono', monospace;
    font-size: 9px;
    color: var(--text-dim);
    display: block;
    margin-top: 2px;
  }

  /* Graph canvas */
  #graphCanvas {
    width: 100%;
    height: 280px;
    background: rgba(0,0,0,0.7);
    border: 1px solid var(--border-cyan);
    cursor: crosshair;
  }

  /* Matrix display */
  .matrix-display {
    font-family: 'Share Tech Mono', monospace;
    font-size: 12px;
    color: var(--neon-green);
    padding: 8px;
    background: rgba(0,255,136,0.04);
    border: 1px solid rgba(0,255,136,0.15);
    white-space: pre;
    overflow-x: auto;
    line-height: 1.6;
  }

  /* Terminal */
  .terminal {
    background: rgba(0,0,0,0.8);
    border: 1px solid var(--border-cyan);
    font-family: 'Share Tech Mono', monospace;
    font-size: 12px;
  }
  .terminal-output {
    padding: 10px;
    height: 140px;
    overflow-y: auto;
    color: var(--neon-green);
    line-height: 1.6;
  }
  .terminal-output::-webkit-scrollbar { width: 3px; }
  .terminal-output::-webkit-scrollbar-thumb { background: var(--neon-green); }
  .terminal-prompt {
    display: flex;
    align-items: center;
    padding: 6px 10px;
    border-top: 1px solid var(--border-cyan);
    gap: 8px;
  }
  .terminal-prompt span { color: var(--magenta); }
  .terminal-input {
    flex: 1;
    background: transparent;
    border: none;
    color: var(--text-primary);
    font-family: 'Share Tech Mono', monospace;
    font-size: 12px;
    outline: none;
  }

  .err { color: var(--neon-red); }
  .info { color: var(--neon-amber); }

  /* Mode toggle */
  .mode-btns {
    display: flex;
    gap: 6px;
    padding: 8px 12px;
    border-bottom: 1px solid var(--border-cyan);
  }
  .mode-btn {
    padding: 4px 12px;
    background: transparent;
    border: 1px solid var(--border-cyan);
    color: var(--text-dim);
    font-family: 'Orbitron', monospace;
    font-size: 9px;
    cursor: pointer;
    transition: all 0.2s;
    letter-spacing: 1px;
  }
  .mode-btn.active { background: rgba(0,243,255,0.1); color: var(--cyan); border-color: var(--cyan); }

  /* Neon glow animation */
  @keyframes glowCyan {
    0%,100% { box-shadow: 0 0 5px rgba(0,243,255,0.2); }
    50% { box-shadow: 0 0 15px rgba(0,243,255,0.5), 0 0 30px rgba(0,243,255,0.2); }
  }

  .glow-border { animation: glowCyan 3s ease-in-out infinite; }

  /* Responsive */
  @media (max-width: 900px) {
    .main-grid { grid-template-columns: 1fr; }
  }

  /* Tooltip */
  [data-tip] { position: relative; }
  [data-tip]:hover::after {
    content: attr(data-tip);
    position: absolute;
    bottom: calc(100% + 4px);
    left: 50%;
    transform: translateX(-50%);
    background: var(--bg-panel);
    border: 1px solid var(--border-cyan);
    color: var(--cyan);
    font-family: 'Share Tech Mono', monospace;
    font-size: 10px;
    padding: 3px 8px;
    white-space: nowrap;
    z-index: 100;
    pointer-events: none;
  }

  .section-divider {
    border: none;
    border-top: 1px solid var(--border-cyan);
    margin: 4px 0;
    opacity: 0.3;
  }

  .fc-row { display: flex; gap: 6px; }
  .fc-row .fc-input { flex: 1; }
  .fc-row .fc-btn { flex: 0 0 auto; width: auto; padding: 6px 10px; margin-top: 0; }

  .badge {
    display: inline-block;
    padding: 1px 6px;
    background: rgba(255,0,255,0.15);
    border: 1px solid rgba(255,0,255,0.3);
    color: var(--magenta);
    font-family: 'Share Tech Mono', monospace;
    font-size: 9px;
    letter-spacing: 1px;
    margin-left: 6px;
  }

  /* Converter layout */
  .conv-layout {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 8px;
    align-items: center;
  }
  .conv-arrow { color: var(--cyan); font-size: 18px; text-align: center; }

  /* Info box */
  .info-box {
    background: rgba(255,170,0,0.05);
    border: 1px solid rgba(255,170,0,0.2);
    padding: 10px 14px;
    font-family: 'Share Tech Mono', monospace;
    font-size: 11px;
    color: var(--neon-amber);
    line-height: 1.6;
  }

  /* Feature list */
  .feature-list {
    padding: 12px 16px;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 4px;
  }
  .fl-item {
    font-family: 'Share Tech Mono', monospace;
    font-size: 10px;
    color: var(--text-dim);
    padding: 3px 6px;
    border-left: 2px solid rgba(0,243,255,0.2);
    transition: all 0.15s;
    cursor: default;
  }
  .fl-item:hover { color: var(--cyan); border-color: var(--cyan); padding-left: 10px; }
  .fl-item .fl-num { color: var(--magenta); margin-right: 4px; }
</style>
</head>
<body>
<div class="app">
  <!-- Header -->
  <div class="header">
    <div class="logo">NEXUS CALC</div>
    <div style="font-family:'Share Tech Mono',monospace;font-size:11px;color:var(--text-dim)">
      GOD-LEVEL COMPUTATION SYSTEM <span class="badge">v3.0.0</span>
    </div>
    <div class="header-status">
      <div class="status-dot"></div>
      <span id="systemClock">SYSTEM ONLINE</span>
      <span style="color:var(--text-dim)">|</span>
      <span id="clock">00:00:00</span>
    </div>
  </div>

  <!-- Nav Tabs -->
  <div class="tabs">
    <button class="tab active" onclick="switchTab('core')">⬡ CORE</button>
    <button class="tab" onclick="switchTab('advanced')">◈ ADVANCED</button>
    <button class="tab" onclick="switchTab('matrix')">⊞ MATRIX</button>
    <button class="tab" onclick="switchTab('convert')">⇄ CONVERT</button>
    <button class="tab" onclick="switchTab('statistics')">∑ STATS</button>
    <button class="tab" onclick="switchTab('finance')">$ FINANCE</button>
    <button class="tab" onclick="switchTab('graph')">〜 GRAPH</button>
    <button class="tab" onclick="switchTab('science')">⚗ SCIENCE</button>
    <button class="tab" onclick="switchTab('developer')">⌨ DEV</button>
    <button class="tab" onclick="switchTab('features')">☰ 300 FEATURES</button>
  </div>

  <!-- Main grid -->
  <div class="main-grid">
    <!-- Left: Calculator Core -->
    <div>
      <!-- Core calc panel -->
      <div class="panel glow-border">
        <div class="panel-header">
          <div class="ph-dot"></div>
          COMMAND CENTER
          <div class="badge" id="calcMode">DEG</div>
        </div>

        <!-- Mode toggles -->
        <div class="mode-btns">
          <button class="mode-btn active" onclick="setAngleMode('DEG',this)">DEG</button>
          <button class="mode-btn" onclick="setAngleMode('RAD',this)">RAD</button>
          <button class="mode-btn" onclick="setAngleMode('GRAD',this)">GRAD</button>
          <button class="mode-btn" id="modeInv" onclick="toggleInverse()">INV</button>
          <button class="mode-btn" onclick="toggleHyp()">HYP</button>
        </div>

        <!-- Display -->
        <div class="display-area">
          <div class="display-expr" id="expr">—</div>
          <div class="display-main" id="display">0</div>
          <div class="display-mode">
            <span id="modeTag">NORMAL</span>
            <span id="memTag" style="color:var(--text-dim)">MEM: <span id="memVal">0</span></span>
          </div>
        </div>

        <!-- Button grid -->
        <div class="btn-grid">
          <!-- Row 1: Memory -->
          <button class="btn amber" onclick="memStore()" data-tip="Store">MS</button>
          <button class="btn amber" onclick="memRecall()" data-tip="Recall">MR</button>
          <button class="btn amber" onclick="memAdd()" data-tip="Mem+">M+</button>
          <button class="btn amber" onclick="memClear()" data-tip="Clear Mem">MC</button>
          <button class="btn red" onclick="clearAll()">AC</button>

          <!-- Row 2: Trig -->
          <button class="btn magenta" onclick="applyTrig('sin')" id="btn-sin">SIN</button>
          <button class="btn magenta" onclick="applyTrig('cos')" id="btn-cos">COS</button>
          <button class="btn magenta" onclick="applyTrig('tan')" id="btn-tan">TAN</button>
          <button class="btn cyan" onclick="applyFn('log10(')">LOG</button>
          <button class="btn cyan" onclick="applyFn('ln(')">LN</button>

          <!-- Row 3: Powers -->
          <button class="btn cyan" onclick="appendOp('^2')">x²</button>
          <button class="btn cyan" onclick="appendOp('^3')">x³</button>
          <button class="btn cyan" onclick="applyFn('sqrt(')">√x</button>
          <button class="btn cyan" onclick="applyFn('cbrt(')">∛x</button>
          <button class="btn cyan" onclick="appendOp('^')">xʸ</button>

          <!-- Row 4 -->
          <button class="btn" onclick="appendOp('(')">(</button>
