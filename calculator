  const D = a1*b2 - a2*b1;
  if (Math.abs(D) < 1e-12) {
    document.getElementById('linearResult').textContent = 'No unique solution (det = 0)';
  } else {
    const x = (c1*b2 - c2*b1) / D;
    const y = (a1*c2 - a2*c1) / D;
    document.getElementById('linearResult').textContent = `x = ${round(x)}, y = ${round(y)}`;
  }
}

// --- POLYNOMIAL ROOTS ---
function findPolyRoots() {
  const coeffs = document.getElementById('polyCoeffs').value.split(',').map(Number);
  if (coeffs.some(isNaN)) { document.getElementById('polyResult').textContent = 'Invalid'; return; }
  try {
    const poly = new math.PolynomialRoot ? null : null;
    // Use companion matrix via mathjs
    const n = coeffs.length - 1;
    if (n === 2) {
      const [a,b,c] = coeffs;
      const disc = b*b-4*a*c;
      if (disc >= 0) {
        document.getElementById('polyResult').textContent =
          `Roots: ${round((-b+Math.sqrt(disc))/(2*a))}, ${round((-b-Math.sqrt(disc))/(2*a))}`;
      } else {
        const re = -b/(2*a), im = Math.sqrt(-disc)/(2*a);
        document.getElementById('polyResult').textContent = `Roots: ${round(re)}±${round(im)}i`;
      }
      return;
    }
    // Newton's method fallback for higher degree
    let roots = [];
    let working = [...coeffs];
    for (let iter = 0; iter < n; iter++) {
      let x = Math.random() * 10 - 5;
      for (let k = 0; k < 200; k++) {
        let p = 0, dp = 0;
        for (let i = 0; i < working.length; i++) {
          const pw = Math.pow(x, working.length-1-i);
          p += working[i] * pw;
          dp += (working.length-1-i) * working[i] * (pw/x || 0);
        }
        if (Math.abs(dp) < 1e-15) break;
        x -= p/dp;
      }
      roots.push(round(x, 6));
    }
    document.getElementById('polyResult').textContent = 'Approx roots: ' + roots.join(', ');
  } catch(e) {
    document.getElementById('polyResult').textContent = 'Error: ' + e.message;
  }
}

