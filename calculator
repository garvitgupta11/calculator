function termKeyDown(e) {
  if (e.key !== 'Enter') return;
  const input = document.getElementById('termInput').value.trim();
  if (!input) return;
  document.getElementById('termInput').value = '';
  termExec(input);
}

function termLog(text, cls='') {
  const out = document.getElementById('termOutput');
  const line = document.createElement('div');
  line.className = cls;
  line.textContent = text;
  out.appendChild(line);
  out.scrollTop = out.scrollHeight;
}

function termExec(cmd) {
  termLog(`nexus ~$ ${cmd}`, 'info');
  if (cmd === 'clear') {
    document.getElementById('termOutput').innerHTML = '';
    return;
  }
  if (cmd === 'help') {
    termLog('Commands: clear, vars, pi, e, help | Any math expression');
    return;
  }
  if (cmd === 'vars') {
    termLog('π = 3.14159265... | e = 2.71828... | φ = 1.61803...');
    return;
  }
  try {
    const result = math.evaluate(cmd, {pi:Math.PI, e:Math.E});
    termLog(`= ${round(result, 12)}`);
    addHistory(cmd, round(result,12));
  } catch(err) {
    termLog('Error: ' + err.message, 'err');
  }
}

