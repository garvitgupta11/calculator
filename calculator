function plotGraph() {
  const canvas = document.getElementById('graphCanvas');
  const ctx = canvas.getContext('2d');
  canvas.width = canvas.offsetWidth;
  canvas.height = canvas.offsetHeight;
  const W = canvas.width, H = canvas.height;

  const fn1 = document.getElementById('graphFn1').value;
  const fn2 = document.getElementById('graphFn2').value;
  const xmin = parseFloat(document.getElementById('graphXmin').value)||-10;
  const xmax = parseFloat(document.getElementById('graphXmax').value)||10;

  // Background
  ctx.fillStyle = '#000408';
  ctx.fillRect(0,0,W,H);

  // Grid
  ctx.strokeStyle = 'rgba(0,243,255,0.05)';
  ctx.lineWidth = 0.5;
  for (let x=0;x<W;x+=60) { ctx.beginPath();ctx.moveTo(x,0);ctx.lineTo(x,H);ctx.stroke(); }
  for (let y=0;y<H;y+=60) { ctx.beginPath();ctx.moveTo(0,y);ctx.lineTo(W,y);ctx.stroke(); }

  // Axes
  const xScale = W/(xmax-xmin);
  const yRange = (xmax-xmin)*H/W;
  const ymin = -yRange/2, ymax = yRange/2;
  const yScale = H/(ymax-ymin);

  const toCanvas = (x,y) => [(x-xmin)*xScale, H-(y-ymin)*yScale];

  ctx.strokeStyle = 'rgba(0,243,255,0.3)';
  ctx.lineWidth = 1;
  // Y axis
  const ax = toCanvas(0,0)[0];
  ctx.beginPath();ctx.moveTo(ax,0);ctx.lineTo(ax,H);ctx.stroke();
  // X axis
  const ay = toCanvas(0,0)[1];
  ctx.beginPath();ctx.moveTo(0,ay);ctx.lineTo(W,ay);ctx.stroke();

  // Plot function
  const plotFn = (fnStr, color) => {
    if (!fnStr) return;
    ctx.strokeStyle = color;
    ctx.lineWidth = 2;
    ctx.shadowColor = color;
    ctx.shadowBlur = 6;
    ctx.beginPath();
    let first = true;
    for (let px = 0; px < W; px++) {
      const x = xmin + px/xScale;
      const y = evalFn(fnStr, x);
      if (!isFinite(y)) { first=true; continue; }
      const [cx,cy] = toCanvas(x,y);
      if (first) { ctx.moveTo(cx,cy); first=false; }
      else ctx.lineTo(cx,cy);
    }
    ctx.stroke();
    ctx.shadowBlur = 0;
  };

  plotFn(fn1, '#00f3ff');
  plotFn(fn2, '#ff00ff');

  // Axis labels
  ctx.fillStyle = 'rgba(0,243,255,0.6)';
  ctx.font = '10px Share Tech Mono';
  ctx.fillText(`[${xmin}, ${xmax}]`, 4, 12);
  if (fn1) ctx.fillStyle = '#00f3ff'; ctx.fillText(fn1, 4, H-4);

  document.getElementById('graphStatus').textContent =
    `Plotted: ${fn1}${fn2?' | '+fn2:''}  Range: [${xmin},${xmax}]`;
}

// ============================================================
// SCIENCE
// ============================================================
function calcKinematics() {
  const u = parseFloat(document.getElementById('kinU').value);
  const a = parseFloat(document.getElementById('kinA').value);
  const t = parseFloat(document.getElementById('kinT').value);
  const v = u + a*t;
  const s = u*t + 0.5*a*t*t;
  const v2 = Math.sqrt(u*u + 2*a*s);
  document.getElementById('kinResult').innerHTML =
    `v = u+at = ${round(v,4)} m/s<br>s = ut+½at² = ${round(s,4)} m<br>v² = u²+2as → v = ${round(v2,4)} m/s`;
}

function calcTimeDilation() {
  const t0 = parseFloat(document.getElementById('tdT0').value);
  const v = parseFloat(document.getElementById('tdV').value);
  const C = 3e8;
  const gamma = 1/Math.sqrt(1-(v*v));
  const t_dilated = t0 * gamma;
  document.getElementById('tdResult').innerHTML =
    `γ (Lorentz) = ${round(gamma,6)}<br>Δt' = ${round(t_dilated,6)} s<br>Time dilation: +${round((t_dilated-t0)/t0*100,2)}%`;
}

function calcHalfLife() {
  const N0 = parseFloat(document.getElementById('hlN0').value);
  const t12 = parseFloat(document.getElementById('hlT12').value);
  const t = parseFloat(document.getElementById('hlT').value);
  const N = N0 * Math.pow(0.5, t/t12);
  const pct = N/N0*100;
  document.getElementById('hlResult').innerHTML =
    `N(t) = ${round(N,4)}<br>Remaining: ${round(pct,4)}%<br>Decayed: ${round(N0-N,4)} (${round(100-pct,4)}%)`;
}

function calcPH() {
  const H = parseFloat(document.getElementById('phH').value);
  const pH = -Math.log10(H);
  const pOH = 14-pH;
  let type = pH<7?'ACIDIC':pH>7?'BASIC':'NEUTRAL';
  document.getElementById('phResult').innerHTML =
    `pH = ${round(pH,4)}<br>pOH = ${round(pOH,4)}<br>${type}`;
  document.getElementById('phResult').style.color =
    pH<7?'var(--neon-red)':pH>7?'var(--neon-green)':'var(--cyan)';
}

function calcKepler() {
  const a = parseFloat(document.getElementById('kepA').value);
  const T = Math.pow(a, 1.5);
  document.getElementById('kepResult').innerHTML =
    `T = ${round(T,4)} Earth years<br>= ${round(T*365.25,2)} days<br>(a=${a} AU)`;
}

function calcMolarity() {
  const mol = parseFloat(document.getElementById('molMoles').value);
  const vol = parseFloat(document.getElementById('molVol').value);
  const M = mol/vol;
  document.getElementById('molResult').textContent = `Molarity = ${round(M,4)} mol/L`;
}

// ============================================================
// DEVELOPER TOOLS
// ============================================================
function generateHash() {
  const input = document.getElementById('hashInput').value;
  const type = document.getElementById('hashType').value;
  let hash = 0;
  if (type === 'simple' || type === 'djb2') {
    hash = type === 'djb2' ? 5381 : 0;
    for (let i = 0; i < input.length; i++) {
      const c = input.charCodeAt(i);
      if (type === 'djb2') hash = ((hash << 5) + hash) + c;
      else hash = ((hash << 5) - hash) + c;
      hash |= 0;
    }
  } else {
    hash = 2166136261;
    for (let i = 0; i < input.length; i++) {
      hash ^= input.charCodeAt(i);
      hash = (hash * 16777619) >>> 0;
    }
  }
  document.getElementById('hashResult').textContent =
    `0x${(hash >>> 0).toString(16).toUpperCase().padStart(8,'0')} (${hash >>> 0})`;
}

function b64Encode() {
  try {
    const r = btoa(document.getElementById('b64Input').value);
    document.getElementById('b64Result').textContent = r;
  } catch(e) { document.getElementById('b64Result').textContent = 'Error'; }
}

function b64Decode() {
  try {
    const r = atob(document.getElementById('b64Input').value);
    document.getElementById('b64Result').textContent = r;
  } catch(e) { document.getElementById('b64Result').textContent = 'Invalid Base64'; }
}

function convertColor(from) {
  const input = document.getElementById('colorInput').value.trim();
  let r,g,b;
  if (from === 'hex') {
    const hex = input.replace('#','');
    r = parseInt(hex.substr(0,2),16);
    g = parseInt(hex.substr(2,2),16);
    b = parseInt(hex.substr(4,2),16);
  } else {
    [r,g,b] = input.split(',').map(v=>parseInt(v.trim()));
  }
  if (isNaN(r)||isNaN(g)||isNaN(b)) return;
  const hex = '#'+[r,g,b].map(v=>v.toString(16).padStart(2,'0')).join('').toUpperCase();
  const rn=r/255,gn=g/255,bn=b/255;
  const max=Math.max(rn,gn,bn),min=Math.min(rn,gn,bn),l=(max+min)/2;
  const s=max===min?0:(l>0.5?(max-min)/(2-max-min):(max-min)/(max+min));
  let h=0;
  if (max!==min){
    if(max===rn) h=(gn-bn)/(max-min)+(gn<bn?6:0);
    else if(max===gn) h=(bn-rn)/(max-min)+2;
    else h=(rn-gn)/(max-min)+4;
    h*=60;
  }
  document.getElementById('colorPreview').style.background = hex;
  document.getElementById('colorResult').innerHTML =
    `HEX: ${hex}<br>RGB: rgb(${r},${g},${b})<br>HSL: hsl(${Math.round(h)},${Math.round(s*100)}%,${Math.round(l*100)}%)`;
}

function convertUnix() {
  const ts = parseInt(document.getElementById('unixTs').value) || Math.floor(Date.now()/1000);
  const d = new Date(ts * 1000);
  document.getElementById('unixResult').innerHTML =
    `Unix: ${ts}<br>UTC: ${d.toUTCString()}<br>Local: ${d.toLocaleString()}<br>ISO: ${d.toISOString()}`;
}

function calcBitwise() {
  const A = parseInt(document.getElementById('bwA').value);
  const B = parseInt(document.getElementById('bwB').value);
  document.getElementById('bwResult').innerHTML =
    `A AND B = ${A&B} (${(A&B).toString(2)})<br>A OR B = ${A|B} (${(A|B).toString(2)})<br>A XOR B = ${A^B} (${(A^B).toString(2)})<br>NOT A = ${~A} (${(~A>>>0).toString(2).slice(-8)})<br>A<<1 = ${A<<1} | A>>1 = ${A>>1}`;
}

function toRoman() {
  let n = parseInt(document.getElementById('romanInput').value);
  if (isNaN(n)||n<1||n>3999) { document.getElementById('romanResult').textContent = 'Range: 1–3999'; return; }
  const vals = [1000,900,500,400,100,90,50,40,10,9,5,4,1];
  const syms = ['M','CM','D','CD','C','XC','L','XL','X','IX','V','IV','I'];
  let r = '';
  vals.forEach((v,i)=>{ while(n>=v){ r+=syms[i]; n-=v; } });
  document.getElementById('romanResult').textContent = r;
}

function fromRoman() {
  const s = document.getElementById('romanInput').value.toUpperCase();
  const map = {M:1000,D:500,C:100,L:50,X:10,V:5,I:1};
  let n = 0;
  for (let i=0;i<s.length;i++) {
    const cur = map[s[i]||0]||0, next = map[s[i+1]||0]||0;
    n += cur < next ? -cur : cur;
  }
  document.getElementById('romanResult').textContent = n || 'Invalid Roman numeral';
}

