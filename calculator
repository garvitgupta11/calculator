function analyzeStats() {
  const data = document.getElementById('statsData').value.split(',').map(Number).filter(n=>!isNaN(n));
  if (!data.length) return;
  const sorted = [...data].sort((a,b)=>a-b);
  const n = data.length;
  const mean = data.reduce((s,v)=>s+v,0)/n;
  const median = n%2 ? sorted[Math.floor(n/2)] : (sorted[n/2-1]+sorted[n/2])/2;
  const freq = {};
  data.forEach(v=>{freq[v]=(freq[v]||0)+1;});
  const maxFreq = Math.max(...Object.values(freq));
  const mode = Object.keys(freq).filter(k=>freq[k]===maxFreq).join(', ');
  const variance = data.reduce((s,v)=>s+Math.pow(v-mean,2),0)/(n-1);
  const std = Math.sqrt(variance);
  const min = sorted[0], max = sorted[n-1];
  const range = max - min;
  const q1 = sorted[Math.floor(n/4)];
  const q3 = sorted[Math.floor(3*n/4)];

  document.getElementById('descStats').innerHTML =
    `n=${n}<br>Min=${round(min,4)}<br>Max=${round(max,4)}<br>Range=${round(range,4)}<br>Mean=${round(mean,6)}<br>Median=${round(median,6)}<br>Mode=${mode}`;
  document.getElementById('varStats').innerHTML =
    `Variance (s²)=${round(variance,6)}<br>Std Dev (s)=${round(std,6)}<br>Q1=${q1}<br>Q3=${q3}<br>IQR=${q3-q1}<br>Skewness≈${round(3*(mean-median)/std,4)}`;
}

function calcCorrelation() {
  const parts = document.getElementById('corrData').value.split('|');
  if (parts.length < 2) return;
  const x = parts[0].split(',').map(Number);
  const y = parts[1].split(',').map(Number);
  const n = Math.min(x.length,y.length);
  const mx = x.slice(0,n).reduce((s,v)=>s+v,0)/n;
  const my = y.slice(0,n).reduce((s,v)=>s+v,0)/n;
  let cov=0, sx=0, sy=0;
  for (let i=0;i<n;i++) {
    cov += (x[i]-mx)*(y[i]-my);
    sx += (x[i]-mx)**2;
    sy += (y[i]-my)**2;
  }
  const r = cov/Math.sqrt(sx*sy);
  // Linear regression y = mx + b
  const m = cov/sx;
  const b = my - m*mx;
  document.getElementById('corrResult').innerHTML =
    `r = ${round(r,6)} (${Math.abs(r)>0.7?'strong':Math.abs(r)>0.4?'moderate':'weak'})<br>r² = ${round(r*r,6)}<br>Regression: y = ${round(m,4)}x + ${round(b,4)}`;
}

function calcDistribution() {
  const type = document.getElementById('distType').value;
  const mu = parseFloat(document.getElementById('distMu').value)||0;
  const sigma = parseFloat(document.getElementById('distSigma').value)||1;
  const x = parseFloat(document.getElementById('distX').value)||0;
  if (type === 'normal') {
    const z = (x-mu)/sigma;
    const pdf = (1/(sigma*Math.sqrt(2*Math.PI))) * Math.exp(-0.5*z*z);
    // Erfc approximation for CDF
    const t = 1/(1+0.2316419*Math.abs(z));
    const poly = t*(0.319381530+t*(-0.356563782+t*(1.781477937+t*(-1.821255978+t*1.330274429))));
    const cdf = z>=0 ? 1-pdf*poly : pdf*poly;
    document.getElementById('distResult').innerHTML =
      `PDF(x=${x}): ${round(pdf,6)}<br>CDF: ${round(cdf,6)}<br>Z-score: ${round(z,4)}`;
  }
}

