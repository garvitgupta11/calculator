  const c = parseFloat(document.getElementById('qC').value);
  const disc = b*b - 4*a*c;
  if (disc > 0) {
    const x1 = (-b + Math.sqrt(disc)) / (2*a);
    const x2 = (-b - Math.sqrt(disc)) / (2*a);
    document.getElementById('quadResult').textContent = `x₁ = ${round(x1)}, x₂ = ${round(x2)} (real)`;
  } else if (disc === 0) {
    document.getElementById('quadResult').textContent = `x = ${round(-b/(2*a))} (double root)`;
  } else {
    const re = round(-b/(2*a));
    const im = round(Math.sqrt(-disc)/(2*a));
    document.getElementById('quadResult').textContent = `x₁ = ${re}+${im}i, x₂ = ${re}-${im}i (complex)`;
  }
}

