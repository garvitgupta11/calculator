  const b2 = parseFloat(document.getElementById('c2i').value)||0;
  let r, i;
  if (op === '+') { r = a1+a2; i = b1+b2; }
  else if (op === '-') { r = a1-a2; i = b1-b2; }
  else if (op === '*') { r = a1*a2-b1*b2; i = a1*b2+b1*a2; }
  else if (op === '/') {
    const d = a2*a2+b2*b2;
    r = (a1*a2+b1*b2)/d; i = (b1*a2-a1*b2)/d;
  } else if (op === '|') { // magnitude
    r = Math.sqrt(a1*a1+b1*b1);
    document.getElementById('complexResult').textContent = `|z₁| = ${round(r)}`;
    return;
  }
  document.getElementById('complexResult').textContent =
    `= ${round(r)} ${i>=0?'+':'-'} ${round(Math.abs(i))}i`;
}

function complexPolar() {
  const a = parseFloat(document.getElementById('c1r').value)||0;
  const b = parseFloat(document.getElementById('c1i').value)||0;
  const r = Math.sqrt(a*a+b*b);
  const theta = Math.atan2(b,a) * 180/Math.PI;
  document.getElementById('complexResult').textContent =
    `Polar: r=${round(r)}, θ=${round(theta)}° (${round(theta*Math.PI/180, 4)} rad)`;
}

// --- NUMERICAL DIFFERENTIATION ---
function numericalDiff() {
  const fn = document.getElementById('diffFn').value;
  const x0 = parseFloat(document.getElementById('diffPt').value);
  const h = parseFloat(document.getElementById('diffH').value) || 1e-5;
  const f = x => evalFn(fn, x);
  const deriv = (f(x0+h) - f(x0-h)) / (2*h);
  document.getElementById('diffResult').textContent = `f'(${x0}) ≈ ${round(deriv, 8)}`;
}

// --- NUMERICAL INTEGRATION (Simpson's Rule) ---
function numericalIntegral() {
  const fn = document.getElementById('intFn').value;
  const a = parseFloat(document.getElementById('intA').value);
  const b2 = parseFloat(document.getElementById('intB').value);
  const n = Math.max(2, parseInt(document.getElementById('intN').value)||1000);
  const N = n % 2 === 0 ? n : n+1;
  const h = (b2-a)/N;
  let sum = evalFn(fn,a) + evalFn(fn,b2);
  for (let i = 1; i < N; i++) {
    sum += (i%2===0?2:4) * evalFn(fn, a+i*h);
  }
  const result = (h/3) * sum;
  document.getElementById('intResult').textContent =
    `∫[${a},${b2}] ${fn} dx ≈ ${round(result, 8)}`;
}

// --- SEQUENCE & SERIES ---
function calcSequence() {
  const type = document.getElementById('seqType').value;
  const a = parseFloat(document.getElementById('seqA').value);
  const d = parseFloat(document.getElementById('seqD').value);
  const n = parseInt(document.getElementById('seqN').value);
  let terms = [], sum = 0;
  if (type === 'ap') {
    for (let i = 0; i < Math.min(n,8); i++) terms.push(round(a + i*d));
    sum = n/2 * (2*a + (n-1)*d);
  } else if (type === 'gp') {
    for (let i = 0; i < Math.min(n,8); i++) terms.push(round(a * Math.pow(d,i)));
    sum = Math.abs(d) !== 1 ? a*(1-Math.pow(d,n))/(1-d) : a*n;
  } else {
    for (let i = 1; i <= n; i++) sum += i;
    terms = [1,2,3,'...', n];
  }
  document.getElementById('seqResult').innerHTML =
    `Terms: ${terms.join(', ')}${terms.length < n ? '...' : ''}<br>S${n} = ${round(sum)}`;
}

// --- SUMMATION ---
function calcSummation() {
  const fn = document.getElementById('sumFn').value;
  const from = parseInt(document.getElementById('sumFrom').value);
  const to = parseInt(document.getElementById('sumTo').value);
  let sum = 0;
  for (let n = from; n <= to; n++) {
    sum += evalFn(fn.replace(/\bn\b/g,'('+n+')'), n);
  }
  document.getElementById('sumResult').textContent =
    `Σ f(n), n=${from} to ${to} = ${round(sum)}`;
}

// --- TAYLOR SERIES ---
function calcTaylor() {
  const fn = document.getElementById('taylorFn').value;
  const x = parseFloat(document.getElementById('taylorX').value);
  const nTerms = parseInt(document.getElementById('taylorN').value);
  let sum = 0, terms = [];
  for (let n = 0; n < nTerms; n++) {
    let term;
    if (fn === 'sin') term = Math.pow(-1,Math.floor(n/2)) * (n%2===1 ? Math.pow(x,n)/factorial(n) : 0);
    else if (fn === 'cos') term = Math.pow(-1,Math.floor((n+1)/2)) * (n%2===0 ? Math.pow(x,n)/factorial(n) : 0);
    else if (fn === 'exp') term = Math.pow(x,n)/factorial(n);
    else if (fn === 'ln') term = n > 0 ? Math.pow(-1,n+1) * Math.pow(x,n)/n : 0;
    if (term !== 0) { sum += term; terms.push(`T${n}=${round(term,4)}`); }
  }
  const exact = fn==='sin'?Math.sin(x):fn==='cos'?Math.cos(x):fn==='exp'?Math.exp(x):Math.log(1+x);
  document.getElementById('taylorResult').innerHTML =
    `Approx = ${round(sum,8)}<br>Exact = ${round(exact,8)}<br>Error = ${round(Math.abs(exact-sum),10)}`;
}

// --- LIMITS ---
function calcLimit() {
  const fn = document.getElementById('limitFn').value;
  const pt = document.getElementById('limitPt').value.trim();
  let val;
  if (pt === 'inf' || pt === 'infinity') {
    val = evalFn(fn, 1e15);
  } else if (pt === '-inf') {
    val = evalFn(fn, -1e15);
  } else {
    const x0 = parseFloat(pt);
    const eps = 1e-8;
    const f1 = evalFn(fn, x0+eps);
    const f2 = evalFn(fn, x0-eps);
    val = (f1+f2)/2;
  }
  document.getElementById('limitResult').textContent =
    `lim[x→${pt}] ${fn} = ${round(val, 8)}`;
}

// --- PRIME FACTORIZATION ---
function primeFactors() {
  let n = parseInt(document.getElementById('pfInput').value);
  if (n <= 1) { document.getElementById('pfResult').textContent = 'Enter n > 1'; return; }
  const factors = {};
  for (let p = 2; p*p <= n; p++) {
    while (n % p === 0) {
      factors[p] = (factors[p]||0)+1;
      n = Math.floor(n/p);
    }
  }
  if (n > 1) factors[n] = (factors[n]||0)+1;
  const str = Object.entries(factors).map(([p,e]) => e>1?`${p}^${e}`:p).join(' × ');
  document.getElementById('pfResult').textContent = str;
}

// --- ALL FACTORS ---
function allFactors() {
  const n = parseInt(document.getElementById('allFInput').value);
  const factors = [];
  for (let i = 1; i*i <= n; i++) {
    if (n%i===0) {
      factors.push(i);
      if (i !== n/i) factors.push(n/i);
    }
  }
  factors.sort((a,b)=>a-b);
  document.getElementById('allFResult').textContent = `[${factors.join(', ')}] (${factors.length} factors)`;
}

// --- MODULAR INVERSE ---
function modInverse() {
  let a = parseInt(document.getElementById('modA').value);
  const m = parseInt(document.getElementById('modM').value);
  a = ((a % m) + m) % m;
  for (let x = 1; x < m; x++) {
    if ((a * x) % m === 1) {
      document.getElementById('modResult').textContent = `${document.getElementById('modA').value}⁻¹ mod ${m} = ${x}`;
      return;
    }
  }
  document.getElementById('modResult').textContent = 'No inverse exists (not coprime)';
}

// --- EULER'S TOTIENT ---
function eulerTotient() {
  let n = parseInt(document.getElementById('eulerInput').value);
  let result = n;
  let temp = n;
  for (let p = 2; p*p <= temp; p++) {
    if (temp%p===0) {
      while (temp%p===0) temp = Math.floor(temp/p);
      result -= result/p;
    }
  }
  if (temp > 1) result -= result/temp;
  document.getElementById('eulerResult').textContent = `φ(${n}) = ${Math.round(result)}`;
}

// ============================================================
// MATRIX OPERATIONS
// ============================================================
function parseMatrix(str) {
  return str.split(';').map(row => row.split(',').map(Number));
}

function formatMatrix(m) {
  return m.map(row => row.map(v => round(v,6)).join('\t')).join('\n');
}

function matOp(op) {
  try {
    const A = parseMatrix(document.getElementById('matA').value);
    const B = parseMatrix(document.getElementById('matB').value);
    const mA = math.matrix(A);
    const mB = math.matrix(B);
    let result;
    if (op === 'add') result = math.add(mA,mB);
    else if (op === 'sub') result = math.subtract(mA,mB);
    else if (op === 'mul') result = math.multiply(mA,mB);
    else if (op === 'det') {
      document.getElementById('matResult').textContent = `det(A) = ${round(math.det(mA))}`;
      return;
    }
    else if (op === 'inv') result = math.inv(mA);
    else if (op === 'trans') result = math.transpose(mA);
    else if (op === 'rank') {
      // Row echelon rank
      const rows = math.clone(A);
      let r = 0;
      for (let c = 0; c < rows[0].length && r < rows.length; c++) {
        let pivot = -1;
        for (let i = r; i < rows.length; i++) {
          if (Math.abs(rows[i][c]) > 1e-10) { pivot = i; break; }
        }
        if (pivot < 0) continue;
        [rows[r], rows[pivot]] = [rows[pivot], rows[r]];
        const scale = rows[r][c];
        rows[r] = rows[r].map(v => v/scale);
        for (let i = 0; i < rows.length; i++) {
          if (i !== r) {
            const f = rows[i][c];
            rows[i] = rows[i].map((v,j) => v - f*rows[r][j]);
          }
        }
        r++;
      }
      document.getElementById('matResult').textContent = `rank(A) = ${r}`;
      return;
    }
    else if (op === 'eigen') {
      // 2x2 eigenvalues
      if (A.length !== 2) {
        document.getElementById('matResult').textContent = 'Eigenvalues: 2×2 only in this mode';
        return;
      }
      const a=A[0][0],b=A[0][1],c=A[1][0],d=A[1][1];
      const tr=a+d, det_v=a*d-b*c;
      const disc=(tr*tr-4*det_v);
      if (disc>=0) {
        const l1=(tr+Math.sqrt(disc))/2, l2=(tr-Math.sqrt(disc))/2;
        document.getElementById('matResult').textContent = `λ₁ = ${round(l1)}, λ₂ = ${round(l2)}`;
      } else {
        const re=tr/2, im=Math.sqrt(-disc)/2;
        document.getElementById('matResult').textContent = `λ = ${round(re)} ± ${round(im)}i (complex)`;
      }
      return;
    }
    document.getElementById('matResult').textContent = formatMatrix(result.toArray());
  } catch(e) {
    document.getElementById('matResult').textContent = 'ERROR: ' + e.message;
  }
}

// --- VECTOR OPS ---
function vecOp(op) {
  const parseVec = s => s.split(',').map(Number);
  const v1 = parseVec(document.getElementById('vec1').value);
  const v2 = parseVec(document.getElementById('vec2').value);
  let r;
  if (op === 'dot') r = v1.reduce((s,v,i)=>s+v*(v2[i]||0),0);
  else if (op === 'cross') {
    r = `[${v1[1]*v2[2]-v1[2]*v2[1]}, ${v1[2]*v2[0]-v1[0]*v2[2]}, ${v1[0]*v2[1]-v1[1]*v2[0]}]`;
  }
  else if (op === 'mag') r = Math.sqrt(v1.reduce((s,v)=>s+v*v,0));
  else if (op === 'norm') {
    const mag = Math.sqrt(v1.reduce((s,v)=>s+v*v,0));
    r = `[${v1.map(v=>round(v/mag)).join(', ')}]`;
  }
  else if (op === 'angle') {
    const d = v1.reduce((s,v,i)=>s+v*(v2[i]||0),0);
    const m1 = Math.sqrt(v1.reduce((s,v)=>s+v*v,0));
    const m2 = Math.sqrt(v2.reduce((s,v)=>s+v*v,0));
    r = `${round(Math.acos(d/(m1*m2)) * 180/Math.PI)}°`;
  }
  document.getElementById('vecResult').textContent = `Result: ${r !== undefined ? round(r) : '?'}`;
}

